# ============================================================================
# МТБанк — анализ звонков контакт-центра. Конфигурация (скопируйте в .env)
#     cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------- LLM ----
# Любой OpenAI-совместимый эндпоинт. Варианты:
#
# 1) Локальная Ollama из compose-профиля local-llm (нужно ~8 ГБ RAM):
#      docker compose --profile local-llm up -d
#    LLM_BASE_URL=http://ollama:11434/v1
#    LLM_API_KEY=ollama
#    LLM_MODEL=qwen2.5:7b
#
# 2) Groq (бесплатный tier, быстрый инференс):
#    LLM_BASE_URL=https://api.groq.com/openai/v1
#    LLM_API_KEY=gsk_...
#    LLM_MODEL=llama-3.3-70b-versatile
#
# 3) OpenRouter (много моделей, есть бесплатные):
#    LLM_BASE_URL=https://openrouter.ai/api/v1
#    LLM_API_KEY=sk-or-...
#    LLM_MODEL=qwen/qwen-2.5-72b-instruct

LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.1
# JSON-mode (response_format=json_object): выключите, если провайдер не поддерживает
LLM_JSON_MODE=true

# ----------------------------------------------------------------- ASR ----
# large-v3-turbo: быстрее и точнее medium (ТЗ требует medium или выше).
# На слабом CPU можно поставить medium / small (small — вне требований ТЗ).
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_BEAM_SIZE=2
WHISPER_LANGUAGE=ru

# ------------------------------------------------------------- ЛИМИТЫ ----
MAX_UPLOAD_MB=50
MAX_AUDIO_DURATION_SEC=1800
AGENT_TIMEOUT_SEC=120

# ------------------------------------------------------------ OPENWEBUI ----
# Ключ доступа к серверу pipelines (OpenWebUI подключается с этим ключом)
PIPELINES_API_KEY=0p3n-w3bu!
# API-ключ OpenWebUI (Settings → Account → API keys) — нужен pipeline-у,
# чтобы скачивать приложенные в чат файлы. Без него работает вариант с URL.
OPENWEBUI_API_KEY=

# ------------------------------------------------------------- GRAFANA ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ---------------------------------------------------------- ЛОГИРОВАНИЕ ----
LOG_LEVEL=INFO
