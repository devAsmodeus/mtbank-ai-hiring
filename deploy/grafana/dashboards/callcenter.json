{
  "uid": "mtbank-callcenter",
  "title": "МТБанк — Речевая аналитика контакт-центра",
  "tags": ["mtbank", "callcenter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Проанализировано звонков",
      "gridPos": { "h": 6, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "calls_analyzed_total", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Средний quality score",
      "gridPos": { "h": 6, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "call_quality_score_sum / call_quality_score_count",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 55 },
              { "color": "green", "value": 75 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Compliance-нарушения",
      "gridPos": { "h": 6, "w": 5, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "compliance_failed_total", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 времени анализа",
      "gridPos": { "h": 6, "w": 4, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(analyze_duration_seconds_bucket[1h])) by (le))",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Топ тематик обращений",
      "gridPos": { "h": 9, "w": 9, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(calls_by_topic_total) by (topic)",
          "instant": true,
          "legendFormat": "{{topic}}"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] }
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Звонки по тематикам (rate, 15м)",
      "gridPos": { "h": 9, "w": 10, "x": 9, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(calls_by_topic_total[15m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Длительность этапов (p50)",
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum(rate(asr_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "ASR"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.5, sum(rate(agents_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "Агенты"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.5, sum(rate(analyze_duration_seconds_bucket[30m])) by (le))",
          "legendFormat": "Всего"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Распределение quality score (увеличение за 30м)",
      "gridPos": { "h": 8, "w": 9, "x": 10, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(call_quality_score_bucket[30m])) by (le)",
          "legendFormat": "≤{{le}}"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
